# ════════════════════════════════════════════════════════════════════
#  Lingora — channel config example  /  cấu hình kênh mẫu
#  Copy this to channels/<your-channel>/.env and fill in.
#  Sao chép sang channels/<tên-kênh>/.env rồi điền vào.
#
#  Open-source build = ONE video per run, no auto-post, no scheduler.
#  Bản open-source = mỗi lần chạy tạo 1 video, KHÔNG tự đăng, KHÔNG hẹn giờ.
#  (Want auto-post/auto-render to your channels? Self-customize, or
#   contact the author — see README.)
# ════════════════════════════════════════════════════════════════════

# ── REQUIRED / BẮT BUỘC ───────────────────────────────────────────
# Gemini API key(s) — get free at https://aistudio.google.com/apikey
# Multiple keys (comma-separated) auto-rotate when one hits its daily quota.
# Nhiều key cách nhau dấu phẩy → tự xoay vòng khi 1 key hết quota ngày.
GEMINI_API_KEYS=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# ── IMAGE GENERATION (optional) / TẠO ẢNH (tuỳ chọn) ──────────────
# Cloudflare Workers AI (FLUX-1-schnell) — free tier. Format:
#   id1:token1,id2:token2  (multiple accounts rotate on quota 429)
# Leave blank to skip AI scene/character images (layouts still render).
CLOUDFLARE_ACCOUNTS=

# Image style: cartoon (flat 2D, default) | cinematic (realistic photo)
IMAGE_STYLE=cartoon

# ── LANGUAGE / NGÔN NGỮ ───────────────────────────────────────────
# target = language being taught; native = on-screen translation language.
# Ví dụ: dạy tiếng Đức cho người Việt → target=de, native=vi.
#        teach Russian to English speakers → target=ru, native=en.
DEFAULT_TARGET_LANG=de
DEFAULT_NATIVE_LANG=vi
DEFAULT_VOICE_GENDER=any

# ── CHANNEL BRANDING (optional) / THƯƠNG HIỆU KÊNH ────────────────
NICHE=language
TEMPLATE=language
CHANNEL_NAME=My Language Channel
CHANNEL_TAGLINE=5 minutes a day
AVATAR_EMOJI=🌍
VOICE_RATE=-10%
NATIVE_VOICE_RATE=+25%

# ── TELEGRAM (optional — only for the bot/preview workflow) ────────
# Not needed for the single-shot CLI. Để trống nếu chỉ chạy CLI.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_NOTIFY_CHAT_ID=
BOT_POLLING_ENABLED=false

# ── AUTO-POST (ADVANCED — off by default) / TỰ ĐĂNG (NÂNG CAO) ─────
# Open-source build ships with this OFF. Turn on only if you set up
# Facebook tokens + a scheduler yourself (advanced), or contact author.
AUTO_POST_ENABLED=false
AUTO_POST_TZ=Asia/Ho_Chi_Minh
AUTO_POST_SCHEDULE=
AUTO_POST_INTERVAL=120min
AUTO_POST_FB_ENABLED=false
AUTO_POST_TIKTOK_ENABLED=false
# FB destinations (only used if AUTO_POST_FB_ENABLED=true)
FB_POST_REEL_ENABLED=true
FB_POST_STORY_ENABLED=true
FB_POST_VIDEO_ENABLED=false
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
TIKTOK_POST_MODE=draft

# ── SYSTEM / HỆ THỐNG ─────────────────────────────────────────────
# ffmpeg location (leave blank to use ffmpeg on PATH).
FFMPEG_BIN=
HYPERFRAMES_VERSION=0.6.52
