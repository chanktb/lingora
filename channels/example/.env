# ════════════════════════════════════════════════════════════════════
#  Example channel — German for travelers (vi narration).
#  Sao chép thư mục này (channels/example/) sang tên khác để tạo kênh
#  thứ 2 với cấu hình khác (vd. channels/japanese-jlpt/).
# ════════════════════════════════════════════════════════════════════

# ── REQUIRED — paste your Gemini key here (free at aistudio.google.com/apikey)
GEMINI_API_KEYS=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# ── OPTIONAL — Cloudflare Workers AI for scene/character images
#   Format: account_id:api_token  (multiple accounts: id1:tok1,id2:tok2)
CLOUDFLARE_ACCOUNTS=
IMAGE_STYLE=cartoon

# ── Languages ────────────────────────────────────────────────────────
DEFAULT_TARGET_LANG=de
DEFAULT_NATIVE_LANG=vi
DEFAULT_VOICE_GENDER=any

# ── Channel identity (used by auto-topic + on-screen branding) ───────
NICHE=everyday German for travelers
TEMPLATE=language
CHANNEL_NAME=German for Travelers
CHANNEL_TAGLINE=5 minutes a day
AVATAR_EMOJI=🇩🇪
VOICE_RATE=-10%
NATIVE_VOICE_RATE=+25%
