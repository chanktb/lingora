<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1080, height=1920" />
    <link
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600;700;800;900&family=Inter:wght@400;500;600;700;800&family=Noto+Sans+SC:wght@400;500;700;900&family=Noto+Sans+JP:wght@400;500;700;900&family=Noto+Sans+KR:wght@400;500;700;900&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --primary:        {{ theme.primary }};
        --primary-light:  {{ theme.primary_light }};
        --accent:         {{ theme.accent }};
        --accent-gold:    {{ theme.accent_gold }};
        --bg-grad:        {{ theme.bg_grad }};
        --halo-1:         {{ theme.halo_1 }};
        --halo-2:         {{ theme.halo_2 }};
        --primary-rgb:    {{ theme.primary_shadow_rgb }};
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body {
        margin: 0; width: 1080px; height: 1920px; overflow: hidden;
        background: #0a0e27;
        font-family: "Inter", "Be Vietnam Pro",
          "Noto Sans CJK SC", "Noto Sans CJK JP", "Noto Sans CJK KR",
          "Noto Sans SC", "Noto Sans JP", "Noto Sans KR", sans-serif;
        color: #fff;
      }
      .clip { position: absolute; }

      /* PHOTO SCENE — full screen (like fill_blank) */
      #scene { top: 0; left: 0; width: 1080px; height: 1920px; overflow: hidden; }
      #scene img { width: 100%; height: 100%; object-fit: cover; }
      #scene-overlay {
        top: 0; left: 0; width: 1080px; height: 1920px;
        /* Very light overall tint — photo stays clearly visible everywhere.
           Edges slightly darker so title + brand text don't compete with
           bright sky / busy scene elements. */
        background: linear-gradient(180deg,
          rgba(0,0,0,0.40) 0%,
          rgba(0,0,0,0.20) 18%,
          rgba(0,0,0,0.25) 50%,
          rgba(0,0,0,0.25) 80%,
          rgba(0,0,0,0.55) 100%);
        pointer-events: none;
      }

      /* TITLE BANNER */
      /* Safe-zone layout (Reels 1080×1920):
         - vertical: y=285..1635 (4:5 safe band, +285 shift from old 4:5 baseline)
         - horizontal: x=90..990 → 90px clearance both sides so content never
           collides with the right-edge like/comment/share rail or with the
           left-edge caption stack when viewers tap-to-zoom on a Reel. */
      #title-wrap { top: 335px; left: 90px; right: 90px; text-align: center; }
      #title-native {
        font-family: "Be Vietnam Pro", sans-serif;
        font-size: 50px; font-weight: 900; line-height: 1.10;
        color: #fff;
        text-shadow: 0 6px 22px rgba(0,0,0,0.85),
                     0 2px 6px rgba(0,0,0,1);
        text-transform: uppercase;
        letter-spacing: 1.3px;
        margin-bottom: 12px;
      }
      #title-target {
        display: inline-block;
        font-family: "Be Vietnam Pro",
          "Noto Sans CJK SC", "Noto Sans CJK JP", "Noto Sans CJK KR",
          "Noto Sans SC", "Noto Sans JP", "Noto Sans KR", sans-serif;
        font-size: 44px; font-weight: 800;
        color: var(--accent-gold);
        padding: 6px 24px;
        border-radius: 18px;
        background: rgba(0,0,0,0.35);
        backdrop-filter: blur(4px);
        text-shadow: 0 4px 14px rgba(0,0,0,0.85);
      }

      /* TABLE — FULL WIDTH centered in safe zone. No blur (preserves photo
         detail behind table). Very light tint just to anchor the visual.
         Readability comes from heavy multi-layer text-shadow on each cell. */
      #table-wrap {
        top: 555px; left: 90px; right: 90px;
        background: rgba(10, 14, 39, 0.20);
        border: 2px solid rgba(255,255,255,0.45);
        border-radius: 28px;
        padding: 22px;
        box-shadow: 0 14px 36px rgba(0,0,0,0.50),
                    inset 0 1px 0 rgba(255,255,255,0.12);
      }
      .row {
        display: grid;
        grid-template-columns: 1fr 1.5fr 1.1fr;
        gap: 12px;
        padding: 14px 22px;
        align-items: center;
      }
      .row:not(:last-child) {
        border-bottom: 1px solid rgba(255,255,255,0.18);
      }
      .row.header {
        background: linear-gradient(90deg, var(--accent-gold), var(--accent));
        color: #1a0f2e;
        border-radius: 18px;
        font-family: "Be Vietnam Pro", sans-serif;
        font-size: 30px; font-weight: 900;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        margin-bottom: 8px;
      }
      .row.header > div { text-align: center; }
      /* Heavy multi-layer text-shadow creates a thick black "outline" around
         every glyph so text stays crisply readable even on bright/busy photo. */
      .cell-vn {
        font-family: "Be Vietnam Pro", sans-serif;
        font-size: 32px; font-weight: 800;
        color: #fff;
        text-shadow:
          1px 1px 0 rgba(0,0,0,1),
          -1px 1px 0 rgba(0,0,0,1),
          1px -1px 0 rgba(0,0,0,1),
          -1px -1px 0 rgba(0,0,0,1),
          0 0 12px rgba(0,0,0,0.9),
          0 3px 8px rgba(0,0,0,0.95);
      }
      .cell-target {
        font-family: "Be Vietnam Pro",
          "Noto Sans CJK SC", "Noto Sans CJK JP", "Noto Sans CJK KR",
          "Noto Sans SC", "Noto Sans JP", "Noto Sans KR", sans-serif;
        font-size: 32px; font-weight: 900;
        color: var(--accent-gold);
        text-shadow:
          1px 1px 0 rgba(0,0,0,1),
          -1px 1px 0 rgba(0,0,0,1),
          1px -1px 0 rgba(0,0,0,1),
          -1px -1px 0 rgba(0,0,0,1),
          0 0 14px rgba(0,0,0,0.95),
          0 3px 10px rgba(0,0,0,1);
      }
      .cell-pron {
        font-family: "Inter", sans-serif;
        font-size: 22px; font-weight: 700; font-style: italic;
        color: #fff;
        text-shadow:
          1px 1px 0 rgba(0,0,0,1),
          -1px 1px 0 rgba(0,0,0,1),
          1px -1px 0 rgba(0,0,0,1),
          -1px -1px 0 rgba(0,0,0,1),
          0 0 10px rgba(0,0,0,0.85),
          0 2px 6px rgba(0,0,0,0.95);
      }

      /* BRAND ROW + TAGLINE — below table */
      #brand-row {
        top: 1475px; left: 0; right: 0;
        display: flex; flex-direction: row; align-items: center; justify-content: center;
        gap: 18px;
      }
      .brand-logo {
        display: flex; align-items: center; justify-content: center;
        width: 70px; height: 70px;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        border-radius: 50%;
        box-shadow: 0 8px 22px rgba(var(--primary-rgb), 0.55);
      }
      .brand-logo img { width: 78%; height: 78%; object-fit: contain; border-radius: 50%; }
      .brand-emoji { font-size: 42px; line-height: 1; }
      .brand-name {
        font-family: "Be Vietnam Pro", sans-serif;
        font-size: 44px; font-weight: 900; color: #fff;
        text-shadow: 0 4px 18px rgba(0, 0, 0, 0.85);
      }
      #tagline {
        top: 1570px; left: 0; right: 0;
        text-align: center; padding: 0 60px;
        font-family: "Inter", sans-serif;
        font-size: 28px; font-weight: 600;
        color: rgba(255,255,255,0.95);
        letter-spacing: 0.5px;
        text-shadow: 0 3px 12px rgba(0,0,0,0.85);
      }
    </style>
  </head>
  <body>
    <div
      id="root"
      data-composition-id="main"
      data-start="0"
      data-duration="{{ total_duration }}"
      data-width="1080"
      data-height="1920"
    >
      <div id="scene" class="clip" data-start="0" data-duration="{{ total_duration }}" data-track-index="0">
        <img src="static/scene.png" alt="scene" />
      </div>
      <div id="scene-overlay" class="clip" data-start="0" data-duration="{{ total_duration }}" data-track-index="1"></div>

      <div id="title-wrap" class="clip" data-start="0" data-duration="{{ total_duration }}" data-track-index="2">
        <div id="title-native">{{ title_native }}</div>
        <div id="title-target">{{ title_target }}</div>
      </div>

      <div id="table-wrap" class="clip" data-start="0" data-duration="{{ total_duration }}" data-track-index="3">
        <div class="row header">
          <div>{% if native_lang == "en" %}English
               {%- elif native_lang == "ko" %}한국어
               {%- elif native_lang == "ja" %}日本語
               {%- elif native_lang == "es" %}Español
               {%- else %}Việt{% endif %}</div>
          <div>{{ target_lang_name }}</div>
          <div>{% if native_lang == "en" %}Say it
               {%- elif native_lang == "ko" %}발음
               {%- elif native_lang == "ja" %}発音
               {%- elif native_lang == "es" %}Pronunciación
               {%- else %}Đọc{% endif %}</div>
        </div>
        {% for it in items %}
        <div class="row">
          <div class="cell-vn">{{ it.native_answer }}</div>
          <div class="cell-target">{{ it.target_word }}</div>
          {% if it.pronunciation %}<div class="cell-pron">{{ it.pronunciation }}</div>{% endif %}
        </div>
        {% endfor %}
      </div>

      {% if not demo_mode %}
      <div id="brand-row" class="clip" data-start="0" data-duration="{{ total_duration }}" data-track-index="4">
        <div class="brand-logo">
          {% if has_logo %}<img src="static/logo.png" alt="logo" />{% else %}<span class="brand-emoji">{{ avatar_emoji }}</span>{% endif %}
        </div>
        <span class="brand-name">{{ channel_name }}</span>
      </div>

      <div id="tagline" class="clip" data-start="0" data-duration="{{ total_duration }}" data-track-index="5">{{ channel_tagline }}</div>
      {% endif %}
    </div>

    <script>
      function autoFitByLength(rules) {
        for (const rule of rules) {
          document.querySelectorAll(rule.selector).forEach(el => {
            el.style.fontSize = "";
            const len = (el.textContent || "").trim().length;
            const baseFs = parseFloat(getComputedStyle(el).fontSize);
            let scale = 1;
            for (const step of rule.scale_steps) {
              if (len > step.above) scale = step.scale;
            }
            if (scale < 1) {
              el.style.fontSize = (baseFs * scale).toFixed(0) + "px";
            }
          });
        }
      }
      autoFitByLength([
        { selector: "#title-native", scale_steps: [
            { above: 26, scale: 0.88 },
            { above: 34, scale: 0.74 },
            { above: 44, scale: 0.62 },
          ]},
        { selector: ".cell-target", scale_steps: [
            { above: 14, scale: 0.85 },
            { above: 20, scale: 0.72 },
          ]},
        { selector: ".cell-vn", scale_steps: [
            { above: 14, scale: 0.85 },
            { above: 20, scale: 0.72 },
          ]},
      ]);
    </script>
  </body>
</html>
