<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1080, height=1920" />
    <link
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600;700;800;900&family=Inter:wght@400;500;600;700;800&family=Noto+Sans+SC:wght@400;500;700;900&family=Noto+Sans+JP:wght@400;500;700;900&family=Noto+Sans+KR:wght@400;500;700;900&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --primary:        {{ theme.primary }};
        --primary-light:  {{ theme.primary_light }};
        --accent:         {{ theme.accent }};
        --accent-gold:    {{ theme.accent_gold }};
        --bg-grad:        {{ theme.bg_grad }};
        --halo-1:         {{ theme.halo_1 }};
        --halo-2:         {{ theme.halo_2 }};
        --primary-rgb:    {{ theme.primary_shadow_rgb }};
        --left-bg: rgba(255,255,255,0.10);
        --left-border: rgba(255,255,255,0.22);
        --right-bg: rgba(120, 240, 180, 0.18);
        --right-border: rgba(120, 240, 180, 0.5);
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body {
        margin: 0; width: 1080px; height: 1920px; overflow: hidden;
        background: #0a0e27;
        font-family: "Inter", "Be Vietnam Pro",
          "Noto Sans CJK SC", "Noto Sans CJK JP", "Noto Sans CJK KR",
          "Noto Sans SC", "Noto Sans JP", "Noto Sans KR", sans-serif;
        color: #fff;
      }
      .clip { position: absolute; }

      #bg {
        position: absolute; inset: 0;
        background:
          radial-gradient(ellipse 800px 600px at 15% 15%, var(--halo-1), transparent 60%),
          radial-gradient(ellipse 800px 600px at 85% 90%, var(--halo-2), transparent 60%),
          var(--bg-grad);
      }
      .grain {
        position: absolute; inset: 0; opacity: 0.10; pointer-events: none;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
      }

      /* TITLE BANNER TOP */
      #title-wrap { top: 315px; left: 90px; right: 90px; text-align: center; }
      #title-native {
        font-family: "Be Vietnam Pro", sans-serif;
        font-size: 48px; font-weight: 900; line-height: 1.08;
        color: #fff;
        text-shadow: 0 6px 22px rgba(0,0,0,0.6);
        text-transform: uppercase;
        letter-spacing: 1.2px;
        margin-bottom: 10px;
      }
      #title-target {
        font-family: "Be Vietnam Pro",
          "Noto Sans CJK SC", "Noto Sans CJK JP", "Noto Sans CJK KR",
          "Noto Sans SC", "Noto Sans JP", "Noto Sans KR", sans-serif;
        font-size: 36px; font-weight: 700;
        color: var(--accent-gold);
        text-shadow: 0 4px 14px rgba(0,0,0,0.6);
      }

      /* HEADER ROW (column labels) — y shifted 485→475 to give pairs-list
         room to fit 8 rows inside the 4:5 safe zone (y 285-1635). */
      #headers {
        top: 475px; left: 130px; right: 130px;
        display: grid;
        grid-template-columns: 1fr 60px 1fr;
        gap: 14px;
        align-items: center;
      }
      .header-pill {
        padding: 10px 18px;
        border-radius: 16px;
        font-family: "Be Vietnam Pro", sans-serif;
        font-size: 26px; font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-align: center;
      }
      .header-left {
        background: linear-gradient(135deg, rgba(255, 100, 140, 0.85), rgba(255, 60, 100, 0.85));
        color: #fff;
        box-shadow: 0 6px 16px rgba(255, 80, 120, 0.4);
      }
      .header-arrow { text-align: center; }
      .header-right {
        background: linear-gradient(135deg, rgba(80, 230, 160, 0.85), rgba(40, 200, 130, 0.85));
        color: #062014;
        box-shadow: 0 6px 16px rgba(60, 220, 150, 0.4);
      }

      /* PAIRS LIST — CEO bug 2026-06-16: brand-row + tagline were overlapping
         row 8 ("Извините за задержку"). Two-part fix:
         (1) shrink list so its bottom edge stays inside the 4:5 safe zone
             (y ≤ 1635). bottom:200 → bottom:295 → list ends at y=1625.
         (2) push brand-row + tagline BELOW the 4:5 safe zone (see below)
             so 4:5 thumbnail crops + Reels-viewer content area stay clean. */
      #pairs-list {
        top: 540px; left: 90px; right: 90px;
        bottom: 295px;
        display: grid;
        grid-template-rows: repeat(8, 1fr);
        gap: 8px;
      }
      .pair-row {
        display: grid;
        grid-template-columns: 70px 1fr 50px 1fr;
        gap: 8px;
        align-items: center;
      }
      .emoji-cell {
        font-size: 38px; line-height: 1;
        text-align: center;
        background: rgba(255,255,255,0.06);
        border-radius: 16px;
        padding: 8px 0;
        border: 2px solid rgba(255,255,255,0.12);
      }
      .pair-cell {
        padding: 8px 16px;
        border-radius: 14px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 2px;
        min-height: 86px;
      }
      .pair-cell-left {
        background: var(--left-bg);
        border: 2px solid var(--left-border);
      }
      .pair-cell-right {
        background: var(--right-bg);
        border: 2px solid var(--right-border);
      }
      .cell-target {
        font-family: "Be Vietnam Pro",
          "Noto Sans CJK SC", "Noto Sans CJK JP", "Noto Sans CJK KR",
          "Noto Sans SC", "Noto Sans JP", "Noto Sans KR", sans-serif;
        font-size: 28px; font-weight: 800;
        color: #fff;
        line-height: 1.12;
        text-shadow: 0 2px 6px rgba(0,0,0,0.5);
      }
      .pair-cell-right .cell-target { color: var(--accent-gold); }
      .cell-pron {
        font-family: "Inter", sans-serif;
        font-size: 18px; font-weight: 500;
        font-style: italic;
        color: var(--primary-light);
        opacity: 0.92;
        line-height: 1.1;
      }
      .arrow-cell {
        text-align: center;
        font-size: 32px;
        color: var(--accent-gold);
        opacity: 0.85;
        font-weight: 900;
      }

      /* BRAND ROW + TAGLINE (bottom) — moved BELOW the 4:5 safe zone
         (1635) so they never overlap the pairs grid. Buffer 50 px so the
         Reels-viewer doesn't see brand visually touching row 8. */
      #brand-row {
        top: 1685px; left: 0; right: 0;
        display: flex; flex-direction: row; align-items: center; justify-content: center;
        gap: 18px;
      }
      .brand-logo {
        display: flex; align-items: center; justify-content: center;
        width: 70px; height: 70px;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        border-radius: 50%;
        box-shadow: 0 8px 22px rgba(var(--primary-rgb), 0.55);
      }
      .brand-logo img { width: 78%; height: 78%; object-fit: contain; border-radius: 50%; }
      .brand-emoji { font-size: 42px; line-height: 1; }
      .brand-name {
        font-family: "Be Vietnam Pro", sans-serif;
        font-size: 42px; font-weight: 900; color: #fff;
        text-shadow: 0 4px 16px rgba(0, 0, 0, 0.6);
      }
      #tagline {
        top: 1795px; left: 0; right: 0;
        text-align: center; padding: 0 60px;
        font-family: "Inter", sans-serif;
        font-size: 26px; font-weight: 600;
        color: var(--primary-light); opacity: 0.95;
        letter-spacing: 0.5px;
        text-shadow: 0 3px 10px rgba(0,0,0,0.5);
      }
    </style>
  </head>
  <body>
    <div
      id="root"
      data-composition-id="main"
      data-start="0"
      data-duration="{{ total_duration }}"
      data-width="1080"
      data-height="1920"
    >
      <div id="bg" class="clip" data-start="0" data-duration="{{ total_duration }}" data-track-index="0">
        <div class="grain"></div>
      </div>

      <div id="title-wrap" class="clip" data-start="0" data-duration="{{ total_duration }}" data-track-index="1">
        <div id="title-native">{{ title_native }}</div>
        <div id="title-target">{{ title_target }}</div>
      </div>

      <div id="headers" class="clip" data-start="0" data-duration="{{ total_duration }}" data-track-index="2">
        <div class="header-pill header-left">{{ left_header }}</div>
        <div class="header-arrow"><span style="font-size: 26px; color: var(--accent-gold);">→</span></div>
        <div class="header-pill header-right">{{ right_header }}</div>
      </div>

      <div id="pairs-list" class="clip" data-start="0" data-duration="{{ total_duration }}" data-track-index="3">
        {% for p in pairs %}
        <div class="pair-row">
          <div class="emoji-cell">{{ p.emoji }}</div>
          <div class="pair-cell pair-cell-left">
            <div class="cell-target">{{ p.left_target }}</div>
            {% if p.left_pron %}<div class="cell-pron">{{ p.left_pron }}</div>{% endif %}
          </div>
          <div class="arrow-cell">→</div>
          <div class="pair-cell pair-cell-right">
            <div class="cell-target">{{ p.right_target }}</div>
            {% if p.right_pron %}<div class="cell-pron">{{ p.right_pron }}</div>{% endif %}
          </div>
        </div>
        {% endfor %}
      </div>

      {% if not demo_mode %}
      <div id="brand-row" class="clip" data-start="0" data-duration="{{ total_duration }}" data-track-index="4">
        <div class="brand-logo">
          {% if has_logo %}<img src="static/logo.png" alt="logo" />{% else %}<span class="brand-emoji">{{ avatar_emoji }}</span>{% endif %}
        </div>
        <span class="brand-name">{{ channel_name }}</span>
      </div>

      <div id="tagline" class="clip" data-start="0" data-duration="{{ total_duration }}" data-track-index="5">{{ channel_tagline }}</div>
      {% endif %}
    </div>

    <script>
      // Auto-fit long phrases so they don't overflow the cell
      function autoFitByLength(rules) {
        for (const rule of rules) {
          document.querySelectorAll(rule.selector).forEach(el => {
            el.style.fontSize = "";
            const len = (el.textContent || "").trim().length;
            const baseFs = parseFloat(getComputedStyle(el).fontSize);
            let scale = 1;
            for (const step of rule.scale_steps) {
              if (len > step.above) scale = step.scale;
            }
            if (scale < 1) {
              el.style.fontSize = (baseFs * scale).toFixed(0) + "px";
            }
          });
        }
      }
      autoFitByLength([
        { selector: "#title-native", scale_steps: [
            { above: 26, scale: 0.88 },
            { above: 36, scale: 0.74 },
          ]},
        { selector: ".cell-target", scale_steps: [
            { above: 14, scale: 0.88 },
            { above: 20, scale: 0.74 },
            { above: 28, scale: 0.62 },
          ]},
        { selector: ".cell-pron", scale_steps: [
            { above: 16, scale: 0.88 },
            { above: 24, scale: 0.74 },
          ]},
      ]);
    </script>
  </body>
</html>
